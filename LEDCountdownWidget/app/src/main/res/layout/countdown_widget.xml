<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/widget_background"
    android:paddingLeft="16dp"
    android:paddingRight="16dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/widget_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/default_label"
        android:textColor="@color/label_gray"
        android:textSize="11sp"
        android:letterSpacing="0.25"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="4dp" />

    <Chronometer
        android:id="@+id/widget_chronometer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/led_blue"
        android:textSize="30sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:letterSpacing="0.06"
        android:shadowColor="@color/led_blue_dim"
        android:shadowRadius="12"
        android:shadowDx="0"
        android:shadowDy="0" />

    <TextView
        android:id="@+id/widget_reached"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_reached_text"
        android:textColor="@color/reached_green"
        android:textSize="26sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:visibility="gone" />

</LinearLayout>
